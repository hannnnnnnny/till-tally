# Base URL for the API.
# Leave empty in development to use the Vite dev proxy (/api -> http://localhost:4000).
# Set to the deployed API origin in production, e.g. https://api.example.com
VITE_API_BASE_URL=""

# Build a public frontend-only preview without backend API calls.
# Production Docker deployments should leave this disabled.
VITE_STATIC_PREVIEW="false"
