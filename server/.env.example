# ── Server ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (PostgreSQL, used by Prisma) ────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://tilltally:tilltally@localhost:5432/tilltally?schema=public"

# ── Authentication (JWT) ─────────────────────────────────────────────────
# Generate strong, unique values — e.g. `openssl rand -hex 32`.
# NEVER commit real secrets; this file holds placeholders only.
JWT_ACCESS_SECRET="replace-with-a-long-random-string"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── CSV import ───────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=25

# -- Natural-language analytics planner ---------------------------------------
# The deterministic local planner is the default and requires no model service.
# Set the provider to ollama only when the server can reach a trusted Ollama instance.
ANALYTICS_PLANNER_PROVIDER=local
ANALYTICS_PLANNER_TIMEOUT_MS=8000
ANALYTICS_PLANNER_MAX_RETRIES=1
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b

# ── CORS ─────────────────────────────────────────────────────────────────
# Frontend origin allowed to call the API.
CLIENT_ORIGIN="http://localhost:5173"
