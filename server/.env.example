# ── Server ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (PostgreSQL, used by Prisma) ────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://tilltally:tilltally@localhost:5432/tilltally?schema=public"

# ── Authentication (JWT) ─────────────────────────────────────────────────
# Generate strong, unique values — e.g. `openssl rand -hex 32`.
# NEVER commit real secrets; this file holds placeholders only.
JWT_ACCESS_SECRET="replace-with-a-long-random-string"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── CSV import ───────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=25

# ── CORS ─────────────────────────────────────────────────────────────────
# Frontend origin allowed to call the API.
CLIENT_ORIGIN="http://localhost:5173"
