# Copy this file to .env.production on the Ubuntu server.
# Replace every placeholder before deploying.

# Public URL served by the host Nginx reverse proxy.
PUBLIC_APP_URL=https://tilltally.example.com

# Bind the containerized client only to localhost. Host Nginx exposes 80/443.
APP_BIND_ADDRESS=127.0.0.1
APP_PORT=8080

# PostgreSQL runs inside the Docker network and is not exposed publicly.
POSTGRES_USER=tilltally
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
POSTGRES_DB=tilltally

# Generate unique values with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Keep this aligned with client/nginx.conf client_max_body_size.
MAX_UPLOAD_SIZE_MB=25

# Natural-language planning is deterministic and model-free by default.
# Ollama is optional; leave this as local unless a private model endpoint is available.
ANALYTICS_PLANNER_PROVIDER=local
ANALYTICS_PLANNER_TIMEOUT_MS=8000
ANALYTICS_PLANNER_MAX_RETRIES=1
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=qwen3:4b

# Demo seeding is blocked in production unless this is set to true for a
# deliberate one-off reset. Leave it unset for normal production deployments.
# ALLOW_PRODUCTION_SEED=true
